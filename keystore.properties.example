# Copy to keystore.properties (git-ignored) and fill in to sign release builds
# with the real upload key. Both :app and :wear read this file; they MUST share
# one key — the Wearable Data Layer only pairs identically-signed packages.
#
# Generate a keystore with:
#   keytool -genkeypair -v -keystore upload-keystore.jks -alias upload \
#     -keyalg RSA -keysize 2048 -validity 10000
storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
