<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+. Same content for cloud backup and device-to-device transfer:
     local settings and temperature history only. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="." />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
